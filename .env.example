APP_NAME="SEMICON Chatbot"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

ADMIN_KEY=semicon-admin-2026

# kb | claude | openai | cursor | auto
CHATBOT_AI_PROVIDER=auto
CHATBOT_MAX_RESPONSE_TOKENS=80

# AI providers (optional — auto mode uses KB first)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CURSOR_CLI_ENABLED=false
CURSOR_CLI_COMMAND=cursor agent --print --output-format text
CHATBOT_AUTO_LEARN=true
CHATBOT_MEMORY_TURNS=6
CHATBOT_LEARN_MIN_HITS=2

# Frontend build (leave empty to use same origin in Docker)
VITE_API_URL=
